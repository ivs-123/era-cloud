{
  "name": "@era/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "start": "node dist/server.js",
    "test": "vitest run --exclude dist/**",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@era/common": "file:../../packages/common",
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "pg": "^8.20.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
